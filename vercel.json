{
  "name": "qa-power-suite",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_NAME": "QA Power Suite",
    "NEXT_PUBLIC_APP_VERSION": "1.0.0"
  }
}
